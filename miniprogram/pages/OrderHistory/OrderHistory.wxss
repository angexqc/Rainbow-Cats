page {
  background-color: var(--rc-bg);
}

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.header {
  height: 56px;
  padding: 0 16px;
  box-sizing: border-box;
  background-color: var(--rc-surface);
  border-bottom: 1px solid var(--rc-border);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.header-right {
  width: 24px;
}

.title {
  font-size: 18px;
  font-weight: 600;
  color: var(--rc-text);
}

.content {
  flex: 1;
  min-height: 0;
  padding: 24px 16px;
  box-sizing: border-box;
}

.status-tabs {
  margin-bottom: 16px;
  display: flex;
  gap: 8px;
  overflow-x: auto;
  white-space: nowrap;
}

.chip {
  height: 32px;
  padding: 0 12px;
  border-radius: 16px;
  background-color: var(--rc-chip-bg);
  color: var(--rc-text-secondary);
  font-size: 14px;
  display: flex;
  align-items: center;
}

.chip.active {
  background-color: var(--rc-primary);
  color: #ffffff;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.order-item {
  background-color: var(--rc-surface);
  border-radius: var(--rc-radius-field);
  padding: 12px;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-time {
  font-size: 12px;
  color: var(--rc-text-secondary);
}

.divider {
  margin: 10px 0;
  height: 1px;
  background-color: var(--rc-border);
}

.status-tag {
  border-radius: 4px;
  padding: 2px 8px;
  font-size: 12px;
}

.status-tag.status-pending {
  background-color: var(--rc-warning-bg);
  color: var(--rc-warning);
}

.status-tag.status-confirmed {
  background-color: #fff7f9;
  color: var(--rc-primary-strong);
}

.status-tag.status-completed {
  background-color: var(--rc-success-bg);
  color: var(--rc-success);
}

.status-tag.status-cancelled {
  background-color: var(--rc-muted-bg);
  color: var(--rc-muted);
}

.order-items {
  font-size: 14px;
  color: var(--rc-text);
  line-height: 1.5;
}

.timeline-flow {
  margin-top: 10px;
  padding: 10px 12px;
  border-radius: 8px;
  background: #fafafa;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.flow-node {
  display: flex;
  align-items: flex-start;
  gap: 8px;
}

.flow-node.single {
  align-items: center;
}

.flow-left {
  width: 12px;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 28px;
}

.flow-point {
  width: 8px;
  height: 8px;
  border-radius: 4px;
  background: #cfcfcf;
  margin-top: 4px;
}

.flow-node.single .flow-left {
  min-height: 16px;
  justify-content: center;
}

.flow-node.single .flow-point {
  margin-top: 0;
}

.flow-texts {
  flex: 1;
  min-width: 0;
}

.flow-title {
  font-size: 13px;
  color: var(--rc-text);
  line-height: 1.25;
  flex-shrink: 0;
}

.flow-meta {
  font-size: 11px;
  color: var(--rc-text-secondary);
  line-height: 1.3;
}

.flow-meta.time {
  color: #b3b3b3;
  flex-shrink: 0;
}

.flow-row {
  display: flex;
  align-items: center;
  gap: 8px;
  min-width: 0;
}

.flow-actor-time {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 6px;
}

.flow-meta.actor-name {
  max-width: 88px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.actor-avatar {
  width: 16px;
  height: 16px;
  border-radius: 8px;
  background: #f2f2f2;
  flex-shrink: 0;
}

.actor-avatar-text {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 9px;
  color: #8a8a8a;
}

.flow-line {
  margin-top: 4px;
  width: 1px;
  flex: 1;
  min-height: 16px;
  background: #d8d8d8;
}

.flow-point.active {
  background: var(--rc-primary);
}

.order-footer {
  margin-top: 10px;
  display: flex;
  justify-content: flex-end;
}

.order-credit {
  font-size: 14px;
  font-weight: 500;
  color: var(--rc-text);
}

.feedback-row {
  margin-top: 10px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.like-icon-btn {
  width: 30px;
  height: 30px;
  border-radius: 15px;
  border: 1px solid var(--rc-border);
  background: #fff;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.like-icon-btn.active {
  border-color: #ffd2dd;
  background: #fff6f8;
}

.like-icon {
  font-size: 15px;
  color: #c7c7c7;
  line-height: 1;
}

.like-icon-btn.active .like-icon {
  color: var(--rc-primary-strong);
}

.feedback-btn {
  min-width: 68px;
  height: 30px;
  padding: 0 10px;
  border-radius: 15px;
  font-size: 12px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 1px solid var(--rc-border);
  color: var(--rc-text-secondary);
  background: #fff;
}

.feedback-btn.review-btn {
  color: var(--rc-primary-strong);
  border-color: #ffd2dd;
  background: #fff;
}

.review-box {
  margin-top: 10px;
  padding: 8px 10px;
  border-radius: 8px;
  background: #fff8fa;
  border: 1px solid #ffe2e9;
}

.review-label {
  font-size: 12px;
  color: var(--rc-text-secondary);
}

.review-text {
  font-size: 12px;
  color: var(--rc-text);
  line-height: 1.5;
}

.empty-state {
  text-align: center;
  color: var(--rc-text-secondary);
  font-size: 14px;
  padding: 72px 0;
}

.load-more {
  text-align: center;
  color: var(--rc-text-secondary);
  font-size: 12px;
  padding: 14px 0 0;
}
