page {
  background-color: var(--rc-bg);
}

.page {
  min-height: 100vh;
}

.header {
  height: 56px;
  padding: 0 16px;
  box-sizing: border-box;
  background-color: var(--rc-surface);
  border-bottom: 1px solid var(--rc-border);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.cancel-text,
.save-text {
  font-size: 14px;
}

.cancel-text {
  color: var(--rc-text-secondary);
}

.save-text {
  color: var(--rc-primary);
  font-weight: 600;
}

.title-text {
  font-size: 18px;
  font-weight: 600;
  color: var(--rc-text);
}

.content {
  padding: 24px 16px;
}

.form-group {
  margin-bottom: 16px;
}

.label {
  font-size: 14px;
  color: var(--rc-text);
  margin-bottom: 8px;
  font-weight: 500;
}

.required {
  color: var(--rc-warning);
}

.input,
.textarea,
.picker {
  border: 1px solid var(--rc-border);
  border-radius: var(--rc-radius-field);
  background-color: var(--rc-surface);
}

.input {
  height: 48px;
  padding: 0 16px;
  font-size: 14px;
}

.textarea {
  min-height: 120px;
  padding: 12px;
  font-size: 14px;
}

.picker {
  height: 48px;
  padding: 0 16px;
  font-size: 14px;
  display: flex;
  align-items: center;
}

.image-upload {
  height: 200px;
  background-color: var(--rc-surface);
  border: 1px dashed var(--rc-border);
  border-radius: var(--rc-radius-field);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  font-size: 14px;
  color: var(--rc-text-secondary);
}

.upload-tip {
  font-size: 12px;
  color: var(--rc-text-secondary);
  margin-top: 8px;
  text-align: center;
}

.toggle-group {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: var(--rc-surface);
  border: 1px solid var(--rc-border);
  border-radius: var(--rc-radius-field);
  padding: 14px 16px;
}

.toggle-label {
  font-size: 14px;
  color: var(--rc-text);
}
