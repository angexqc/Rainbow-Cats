<view class="page">
  <view class="header" style="padding-top: {{topSafeHeight}}px; height: {{topSafeHeight + 56}}px;">
    <text class="cancel-text" bindtap="handleCancel">取消</text>
    <text class="title-text">编辑菜品</text>
    <text class="save-text" bindtap="handleSave">保存</text>
  </view>

  <view class="content" wx:if="{{menu}}">
    <view class="form-group">
      <view class="label">菜品名称 <text class="required">*</text></view>
      <input class="input" type="text" placeholder="请输入菜品名称" maxlength="20" value="{{title}}" bindinput="onTitleInput" />
    </view>

    <view class="form-group">
      <view class="label">菜品图片 <text class="required">*</text></view>
      <view class="image-upload" bindtap="chooseImage">
        <image wx:if="{{image}}" class="preview" src="{{image}}" mode="aspectFill"></image>
        <view wx:else class="upload-placeholder">点击上传图片</view>
      </view>
      <view class="upload-tip">建议比例 1:1</view>
    </view>

    <view class="form-group">
      <view class="label">菜品描述</view>
      <textarea class="textarea" placeholder="请输入菜品描述" maxlength="100" value="{{desc}}" bindinput="onDescInput" />
    </view>

    <view class="form-group">
      <view class="label">分类 <text class="required">*</text></view>
      <picker bindchange="onCategoryChange" value="{{categoryIndex}}" range="{{categories}}">
        <view class="picker">
          {{categories[categoryIndex]}}
        </view>
      </picker>
    </view>

    <view class="form-group toggle-group">
      <view class="toggle-label">立即上架</view>
      <switch checked="{{available}}" bindchange="onToggleAvailable" />
    </view>
  </view>
</view>
