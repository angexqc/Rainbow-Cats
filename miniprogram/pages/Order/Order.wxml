<view class="page">
  <view class="header" style="padding-top: {{topSafeHeight}}px; height: {{topSafeHeight + 56}}px;">
    <view class="title">购物车</view>
    <view class="header-actions">
      <view class="icon-action danger" bindtap="clearAll">🗑</view>
    </view>
  </view>

  <view class="content" wx:if="{{cartItems.length > 0}}">
    <view class="toolbar">
      <text class="toolbar-text">已选 {{selectedCount}} 项，共 {{totalCount}} 份</text>
      <view class="toolbar-actions">
        <view class="icon-action" bindtap="toggleSelectAll">{{selectedCount === cartItems.length ? '☑' : '☐'}}</view>
        <view class="icon-action danger" bindtap="deleteBatch">🗑</view>
      </view>
    </view>

    <view class="cart-list">
      <view wx:for="{{cartItems}}" wx:key="menuId" class="cart-item">
        <view class="category-flag">{{item.categoryDisplay || categoryMap[item.category] || item.category || '未分类'}}</view>
        <view class="check {{selectedMap[item.menuId] ? 'checked' : ''}}" bindtap="toggleSelect" data-id="{{item.menuId}}">{{selectedMap[item.menuId] ? '✓' : ''}}</view>
        <image class="thumb" src="{{item.image}}" mode="aspectFill" lazy-load="true" webp></image>
        <view class="info">
          <text class="name">{{item.title}}</text>
          <view class="item-actions">
            <view class="quantity-row">
              <view class="qty-btn" bindtap="decreaseCount" data-id="{{item.menuId}}">-</view>
              <text class="quantity">{{item.count}}</text>
              <view class="qty-btn" bindtap="increaseCount" data-id="{{item.menuId}}">+</view>
            </view>
            <view class="icon-action danger compact" bindtap="deleteOne" data-id="{{item.menuId}}">🗑</view>
          </view>
        </view>
      </view>
    </view>

    <view class="bottom-bar">
      <view class="summary">共 {{totalCount}} 份</view>
      <view class="biz-action biz-primary submit-btn" bindtap="submitOrder">🧾 下单</view>
    </view>
  </view>

  <view wx:else class="empty-state">
    <text class="empty-title">购物车为空</text>
    <text class="empty-desc">去菜单页添加想吃的菜品</text>
  </view>
</view>
