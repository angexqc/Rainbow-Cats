page {
  background: var(--rc-bg);
}

.page {
  min-height: 100vh;
}

.header {
  padding: 0 16px;
  box-sizing: border-box;
  background: var(--rc-surface);
  border-bottom: 1px solid var(--rc-border);
  display: flex;
  align-items: center;
}

.title {
  font-size: 18px;
  font-weight: 600;
  color: var(--rc-text);
}

.content {
  padding: 18px 16px;
}

.tip {
  font-size: 13px;
  color: var(--rc-text-secondary);
  margin-bottom: 16px;
}

.avatar-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  padding: 18px 0;
  background: var(--rc-surface);
  border-radius: 12px;
}

.avatar {
  width: 84px;
  height: 84px;
  border-radius: 42px;
  background: #f3f3f3;
}

.avatar-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--rc-text-secondary);
  font-size: 12px;
}

.ghost {
  width: 220px;
  height: 36px;
  line-height: 36px;
  border-radius: 18px;
  border: 1px solid var(--rc-border);
  color: var(--rc-text-secondary);
  background: #fff;
  font-size: 13px;
  padding: 0;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ghost::after {
  border: none;
}

.form-item {
  margin-top: 14px;
  background: var(--rc-surface);
  border-radius: 12px;
  padding: 14px;
}

.label {
  display: block;
  font-size: 13px;
  color: var(--rc-text-secondary);
  margin-bottom: 8px;
}

.input {
  height: 42px;
  border: 1px solid var(--rc-border);
  border-radius: 10px;
  padding: 0 12px;
  font-size: 15px;
  color: var(--rc-text);
  background: #fff;
}

.save {
  margin-top: 18px;
  height: 44px;
  line-height: 44px;
  border-radius: 10px;
  background: var(--rc-primary);
  color: #fff;
  font-size: 15px;
  font-weight: 500;
  padding: 0;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}

.save::after {
  border: none;
}
