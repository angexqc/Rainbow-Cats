page {
  background-color: var(--rc-bg);
}

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.header {
  height: 56px;
  padding: 0 16px;
  box-sizing: border-box;
  background-color: var(--rc-surface);
  border-bottom: 1px solid var(--rc-border);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.back-btn,
.header-space {
  width: 24px;
  text-align: center;
  font-size: 20px;
  color: var(--rc-text);
}

.title {
  font-size: 18px;
  font-weight: 600;
  color: var(--rc-text);
}

.content {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  padding: 24px 16px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.status-card,
.card {
  border-radius: var(--rc-radius-card);
  background-color: var(--rc-surface);
  padding: 16px;
}

.status-card {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.status-tag {
  display: inline-flex;
  border-radius: 4px;
  padding: 2px 8px;
  font-size: 12px;
}

.status-tag.status-pending {
  background-color: var(--rc-warning-bg);
  color: var(--rc-warning);
}

.status-tag.status-confirmed {
  background-color: #fff7f9;
  color: var(--rc-primary-strong);
}

.status-tag.status-completed {
  background-color: var(--rc-success-bg);
  color: var(--rc-success);
}

.status-tag.status-cancelled {
  background-color: var(--rc-muted-bg);
  color: var(--rc-muted);
}

.order-no {
  font-size: 14px;
  color: var(--rc-text);
}

.section-title {
  font-size: 14px;
  font-weight: 500;
  color: var(--rc-text);
}

.timeline-flow {
  margin-top: 10px;
  padding: 10px 12px;
  border-radius: 8px;
  background: #fafafa;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.flow-node {
  display: flex;
  align-items: flex-start;
  gap: 8px;
}

.flow-left {
  width: 12px;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 28px;
}

.flow-point {
  width: 8px;
  height: 8px;
  border-radius: 4px;
  background: #cfcfcf;
  margin-top: 4px;
}

.flow-texts {
  flex: 1;
  min-width: 0;
}

.flow-title {
  font-size: 13px;
  color: var(--rc-text);
  line-height: 1.25;
  flex-shrink: 0;
}

.flow-meta {
  font-size: 11px;
  color: var(--rc-text-secondary);
  line-height: 1.3;
}

.flow-meta.time {
  color: #b3b3b3;
  flex-shrink: 0;
}

.flow-row {
  display: flex;
  align-items: center;
  gap: 8px;
  min-width: 0;
}

.flow-actor-time {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 6px;
}

.flow-meta.actor-name {
  max-width: 88px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.actor-avatar {
  width: 16px;
  height: 16px;
  border-radius: 8px;
  background: #f2f2f2;
  flex-shrink: 0;
}

.actor-avatar-text {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 9px;
  color: #8a8a8a;
}

.flow-line {
  margin-top: 4px;
  width: 1px;
  flex: 1;
  min-height: 16px;
  background: #d8d8d8;
}

.flow-point.active {
  background: var(--rc-primary);
}

.items-list {
  margin-top: 12px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.item-row {
  display: flex;
  gap: 12px;
}

.item-thumb {
  width: 48px;
  height: 48px;
  border-radius: 4px;
  background-color: var(--rc-bg);
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.item-name {
  font-size: 14px;
  color: var(--rc-text);
}

.item-credit {
  margin-top: 4px;
  font-size: 12px;
  color: var(--rc-text-secondary);
}

.total-row {
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px solid var(--rc-border);
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 8px;
}

.total-label {
  font-size: 14px;
  color: var(--rc-text);
}

.total-credit {
  font-size: 16px;
  font-weight: 600;
  color: var(--rc-text);
}

.remark-text {
  margin-top: 10px;
  font-size: 14px;
  color: var(--rc-text);
  line-height: 1.6;
}

.feedback-row {
  margin-top: 10px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.like-icon-btn {
  width: 32px;
  height: 32px;
  border-radius: 16px;
  border: 1px solid var(--rc-border);
  background: #fff;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.like-icon-btn.active {
  border-color: #ffd2dd;
  background: #fff6f8;
}

.like-icon {
  font-size: 16px;
  color: #c7c7c7;
  line-height: 1;
}

.like-icon-btn.active .like-icon {
  color: var(--rc-primary-strong);
}

.feedback-btn {
  min-width: 78px;
  height: 32px;
  padding: 0 12px;
  border-radius: 16px;
  font-size: 12px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 1px solid #ffd2dd;
  color: var(--rc-primary-strong);
  background: #fff;
}

.review-box {
  margin-top: 10px;
  padding: 8px 10px;
  border-radius: 8px;
  background: #fff8fa;
  border: 1px solid #ffe2e9;
}

.review-label {
  font-size: 12px;
  color: var(--rc-text-secondary);
}

.review-text {
  font-size: 12px;
  color: var(--rc-text);
  line-height: 1.5;
}

.actions {
  margin-top: 2px;
  display: flex;
  gap: 12px;
}

.btn {
  flex: 1;
  height: 44px;
  border-radius: var(--rc-radius-field);
  font-size: 14px;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary {
  background-color: var(--rc-primary);
  color: #ffffff;
}

.btn-cancel {
  background-color: var(--rc-surface);
  border: 1px solid var(--rc-primary);
  color: var(--rc-primary);
}
