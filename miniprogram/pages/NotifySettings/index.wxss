page {
  background-color: var(--rc-bg);
}

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.header {
  height: 56px;
  padding: 0 16px;
  box-sizing: border-box;
  background-color: var(--rc-surface);
  border-bottom: 1px solid var(--rc-border);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.back-btn,
.header-space {
  width: 24px;
  text-align: center;
  font-size: 20px;
  color: var(--rc-text);
}

.title {
  font-size: 18px;
  font-weight: 600;
  color: var(--rc-text);
}

.content {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  padding: 14px;
  box-sizing: border-box;
}

.block {
  background: #fff;
  border-radius: 14px;
  padding: 14px;
  margin-bottom: 12px;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
}

.main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.label {
  font-size: 15px;
  color: #222;
  font-weight: 600;
}

.desc {
  font-size: 12px;
  color: #8c8c8c;
}

.status-row {
  height: 34px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.input-row {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-bottom: 8px;
}

.template-input {
  height: 36px;
  line-height: 36px;
  border: 1px solid #ffd2dd;
  border-radius: 10px;
  padding: 0 10px;
  font-size: 13px;
  color: #333;
  background: #fff;
}

.template-preview {
  margin-top: 8px;
  padding: 8px 10px;
  background: #fff8fa;
  border: 1px solid #ffd2dd;
  border-radius: 10px;
}

.preview-line {
  display: block;
  font-size: 12px;
  color: #666;
  line-height: 1.5;
  margin-bottom: 4px;
  word-break: break-all;
}

.status-label {
  font-size: 13px;
  color: #666;
}

.status-value {
  font-size: 13px;
  font-weight: 600;
}

.status-value.on {
  color: #2fad68;
}

.status-value.off {
  color: #c08f9d;
}

.btn {
  margin-top: 10px;
  height: 38px;
  border-radius: 19px;
  background: linear-gradient(135deg, #ff9fb1, #ff7f99);
  color: #fff;
  font-size: 13px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn::after {
  border: none;
}

.btn.ghost {
  background: #fff8fa;
  color: #ff6f93;
  border: 1px solid #ffd2dd;
}
