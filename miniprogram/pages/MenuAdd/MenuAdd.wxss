page {
  background-color: var(--rc-bg);
}

.page {
  min-height: 100vh;
}

.header {
  height: 56px;
  padding: 0 16px;
  box-sizing: border-box;
  background-color: var(--rc-surface);
  border-bottom: 1px solid var(--rc-border);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.cancel-text,
.save-text {
  font-size: 14px;
}

.cancel-text {
  color: var(--rc-text-secondary);
}

.save-text {
  color: var(--rc-primary);
  font-weight: 600;
}

.title {
  font-size: 18px;
  font-weight: 600;
  color: var(--rc-text);
}

.content {
  padding: 24px 16px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.label {
  font-size: 14px;
  font-weight: 500;
  color: var(--rc-text);
}

.required {
  color: var(--rc-warning);
}

.input-wrap,
.upload-box {
  background-color: var(--rc-surface);
  border: 1px solid var(--rc-border);
  border-radius: var(--rc-radius-field);
}

.input-wrap {
  height: 48px;
  display: flex;
  align-items: center;
  padding: 0 12px;
  box-sizing: border-box;
}

.input {
  width: 100%;
  height: 100%;
  font-size: 14px;
  color: var(--rc-text);
}

.placeholder {
  color: var(--rc-text-secondary);
}

.upload-box {
  height: 180px;
  border-style: dashed;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.upload-text {
  font-size: 14px;
  color: var(--rc-text-secondary);
}

.upload-preview {
  width: 100%;
  height: 100%;
}

.hint {
  font-size: 12px;
  color: var(--rc-text-secondary);
  text-align: center;
}

.textarea-wrap {
  min-height: 108px;
  align-items: flex-start;
  padding: 12px;
}

.textarea {
  width: 100%;
  min-height: 84px;
  font-size: 14px;
  color: var(--rc-text);
}

.picker-wrap {
  justify-content: space-between;
}

.picker-text {
  font-size: 14px;
  color: var(--rc-text);
}

.picker-arrow {
  font-size: 18px;
  color: #aaaaaa;
}
