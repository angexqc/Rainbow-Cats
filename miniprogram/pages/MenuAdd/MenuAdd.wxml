<view class="page">
  <view class="header">
    <text class="cancel-text" bindtap="handleCancel">取消</text>
    <text class="title">添加菜品</text>
    <text class="save-text" bindtap="handleSave">保存</text>
  </view>

  <view class="content">
    <view class="field">
      <view class="label">菜品名称 <text class="required">*</text></view>
      <view class="input-wrap">
        <input class="input" type="text" placeholder="请输入菜品名称" maxlength="20" placeholder-class="placeholder" value="{{title}}" bindinput="onTitleInput" />
      </view>
    </view>

    <view class="field">
      <view class="label">菜品图片 <text class="required">*</text></view>
      <view class="upload-box" bindtap="chooseImage">
        <image wx:if="{{image}}" src="{{image}}" mode="aspectFill" class="upload-preview"></image>
        <view wx:else class="upload-text">点击上传图片</view>
      </view>
      <view class="hint">建议比例 1:1</view>
    </view>

    <view class="field">
      <view class="label">菜品描述</view>
      <view class="input-wrap textarea-wrap">
        <textarea class="textarea" placeholder="请输入菜品描述" maxlength="100" placeholder-class="placeholder" value="{{desc}}" bindinput="onDescInput"></textarea>
      </view>
    </view>

    <view class="field">
      <view class="label">分类 <text class="required">*</text></view>
      <picker bindchange="onCategoryChange" value="{{categoryIndex}}" range="{{categories}}">
        <view class="input-wrap picker-wrap">
          <view class="picker-text">{{categories[categoryIndex]}}</view>
          <view class="picker-arrow">›</view>
        </view>
      </picker>
    </view>
  </view>
</view>
