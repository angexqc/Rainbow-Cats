page {
  background-color: var(--rc-bg);
}

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.header {
  height: 56px;
  padding: 0 16px;
  box-sizing: border-box;
  background-color: var(--rc-surface);
  border-bottom: 1px solid var(--rc-border);
  display: flex;
  align-items: center;
  justify-content: center;
}

.title {
  font-size: 18px;
  font-weight: 600;
  color: var(--rc-text);
}

.content {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  padding: 12px 16px 18px;
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.unpaired-card,
.paired-card,
.qr-card,
.code-card {
  background-color: var(--rc-surface);
  border-radius: var(--rc-radius-card);
  padding: 16px;
}

.card-title {
  font-size: 16px;
  font-weight: 500;
  color: var(--rc-text);
}

.card-desc {
  margin-top: 8px;
  font-size: 12px;
  color: var(--rc-text-secondary);
}

.section-title {
  font-size: 14px;
  font-weight: 500;
  color: var(--rc-text);
}

.qr-card {
  min-height: 220px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 12px;
}

.qr-placeholder {
  width: 160px;
  height: 160px;
  border-radius: var(--rc-radius-field);
  background-color: var(--rc-bg);
  color: var(--rc-text-secondary);
  font-size: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qr-image {
  width: 160px;
  height: 160px;
  border-radius: var(--rc-radius-field);
  background-color: #ffffff;
}

.qr-text {
  font-size: 14px;
  font-weight: 500;
  color: var(--rc-text);
}

.qr-text-row {
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8px;
}

.copy-icon-btn {
  width: 24px;
  height: 24px;
  border-radius: 12px;
  background: #fff8fa;
  border: 1px solid #ffd2dd;
  color: var(--rc-primary-strong);
  text-align: center;
  line-height: 24px;
  font-size: 12px;
}

.input-row {
  width: 100%;
  display: flex;
  gap: 8px;
}

.code-input {
  flex: 4;
  height: 44px;
  background-color: var(--rc-surface);
  border: 1px solid var(--rc-border);
  border-radius: var(--rc-radius-field);
  display: flex;
  align-items: center;
  padding-right: 6px;
  box-sizing: border-box;
}

.code-input input {
  width: 100%;
  height: 100%;
  padding: 0 10px 0 12px;
  box-sizing: border-box;
  font-size: 14px;
  color: var(--rc-text);
}

.scan-icon-btn {
  width: 30px;
  height: 30px;
  border-radius: 15px;
  background: #fff8fa;
  border: 1px solid #ffd2dd;
  position: relative;
  flex-shrink: 0;
  box-sizing: border-box;
}

.scan-corner {
  position: absolute;
  width: 6px;
  height: 6px;
  border-color: var(--rc-primary-strong);
}

.scan-corner.tl {
  left: 7px;
  top: 7px;
  border-left: 1.5px solid var(--rc-primary-strong);
  border-top: 1.5px solid var(--rc-primary-strong);
}

.scan-corner.tr {
  right: 7px;
  top: 7px;
  border-right: 1.5px solid var(--rc-primary-strong);
  border-top: 1.5px solid var(--rc-primary-strong);
}

.scan-corner.bl {
  left: 7px;
  bottom: 7px;
  border-left: 1.5px solid var(--rc-primary-strong);
  border-bottom: 1.5px solid var(--rc-primary-strong);
}

.scan-corner.br {
  right: 7px;
  bottom: 7px;
  border-right: 1.5px solid var(--rc-primary-strong);
  border-bottom: 1.5px solid var(--rc-primary-strong);
}

.scan-line {
  position: absolute;
  left: 8px;
  right: 8px;
  top: 14px;
  height: 1.5px;
  border-radius: 1px;
  background: #ff8ca7;
}

.placeholder {
  color: var(--rc-text-secondary);
}

.bind-btn,
.regen-btn,
.unbind-btn,
.skip-btn {
  height: 44px;
  border-radius: var(--rc-radius-field);
  font-size: 14px;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bind-btn {
  flex: 2;
  min-width: 0;
  background-color: var(--rc-primary);
  color: #ffffff;
}

.bind-btn[disabled] {
  background-color: var(--rc-border);
  color: var(--rc-text-secondary);
}

.expire-tip {
  text-align: center;
  font-size: 12px;
  color: var(--rc-text-secondary);
}

.skip-btn {
  width: 100%;
  color: var(--rc-text-secondary);
  border: 1px solid var(--rc-border);
  background-color: var(--rc-surface);
}

.skip-entry {
  width: 100%;
  min-height: 60px;
  padding: 12px 14px;
  border-radius: var(--rc-radius-card);
  border: 1px solid #ffdbe4;
  background: linear-gradient(135deg, #fffafc 0%, #fff4f7 100%);
  box-shadow: 0 6px 14px rgba(248, 168, 190, 0.12);
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
}

.skip-copy {
  flex: 1;
  min-width: 0;
}

.skip-title {
  font-size: 14px;
  line-height: 20px;
  color: #d85c7f;
  font-weight: 600;
}

.skip-subtitle {
  margin-top: 2px;
  font-size: 12px;
  line-height: 18px;
  color: #a58a93;
}

.skip-arrow {
  flex-shrink: 0;
  width: 24px;
  height: 24px;
  border-radius: 12px;
  background: rgba(255, 133, 165, 0.14);
  color: #d85c7f;
  font-size: 18px;
  line-height: 24px;
  text-align: center;
}

.paired-card {
  display: flex;
  align-items: center;
  gap: 12px;
}

.avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background-color: var(--rc-bg);
}

.partner-name {
  font-size: 14px;
  font-weight: 500;
  color: var(--rc-text);
}

.bind-time {
  margin-top: 4px;
  font-size: 12px;
  color: var(--rc-text-secondary);
}

.paired-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.regen-btn {
  width: 100%;
  background-color: var(--rc-primary);
  color: #ffffff;
}

.home-btn {
  width: 100%;
  height: 44px;
  border-radius: var(--rc-radius-field);
  background-color: #ffffff;
  color: var(--rc-primary);
  border: 1px solid var(--rc-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 500;
}

.code-label {
  font-size: 12px;
  color: var(--rc-text-secondary);
}

.code-text {
  margin-top: 8px;
  font-size: 16px;
  font-weight: 600;
  letter-spacing: 1px;
  color: var(--rc-primary-strong);
}

.unbind-btn {
  width: 100%;
  color: var(--rc-primary);
  border: 1px solid var(--rc-primary);
  background-color: var(--rc-surface);
}
