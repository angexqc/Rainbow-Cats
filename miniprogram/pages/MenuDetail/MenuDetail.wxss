page {
  background-color: var(--rc-bg);
}

.page {
  min-height: 100vh;
}

.header {
  height: 56px;
  padding: 0 16px;
  box-sizing: border-box;
  border-bottom: 1px solid var(--rc-border);
  background-color: var(--rc-surface);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.header text {
  font-size: 16px;
  color: var(--rc-text);
}

.header text:first-child {
  position: absolute;
  left: 16px;
  font-size: 20px;
}

.content {
  padding: 16px;
}

.big-image {
  width: 100%;
  height: 210px;
  background-color: #f3f3f3;
  border-radius: 12px;
  overflow: hidden;
}

.info-card,
.desc-section {
  background-color: var(--rc-surface);
  border-radius: 12px;
  padding: 16px;
  margin-top: 12px;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.info-row:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 14px;
  color: var(--rc-text-secondary);
  width: 80px;
}

.value {
  font-size: 14px;
  color: var(--rc-text);
  flex: 1;
}

.name {
  font-size: 18px;
  font-weight: 600;
  color: var(--rc-text);
}

.section-title {
  font-size: 14px;
  color: var(--rc-text);
  margin-bottom: 8px;
  font-weight: 500;
}

.desc-text {
  font-size: 14px;
  color: var(--rc-text);
  line-height: 1.6;
}

.actions {
  display: flex;
  gap: 12px;
  margin-top: 14px;
}

.btn {
  flex: 1;
  height: 44px;
  border-radius: 10px;
  border: none;
  font-size: 14px;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-secondary {
  background-color: #ffffff;
  border: 1px solid var(--rc-border);
  color: var(--rc-text-secondary);
}

.btn-danger {
  background-color: #ffffff;
  border: 1px solid #fa5151;
  color: #fa5151;
}

.btn-toggle-on {
  background-color: var(--rc-primary);
  color: #ffffff;
}

.btn-toggle-off {
  background-color: #f2f2f2;
  color: #777777;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80px 0;
}

.loading text {
  color: var(--rc-text-secondary);
}
